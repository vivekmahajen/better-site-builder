{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aastha:temple",
  "title": "Temple",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "deity", "city", "state", "sources", "verification"],
  "properties": {
    "id": { "type": "string", "pattern": "^temple_[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 2 },
    "deity": { "type": "string" },
    "tradition": { "type": "string", "enum": ["Shaiva", "Vaishnava", "Shakta", "Ganapatya", "Saura", "Smarta", "Sikh", "Buddhist", "Jain", "Other"] },
    "city": { "type": "string" },
    "state": { "type": "string" },
    "country": { "type": "string" },
    "darshan": { "type": "object" },
    "official_trust": { "type": ["string", "null"] },
    "imported_from": { "type": "string" },
    "sources": { "$ref": "aastha:common#/$defs/sources" },
    "verification": { "type": "string", "enum": ["verified", "unverified", "needs_review"] },
    "correction_contact": { "type": "string" }
  }
}
