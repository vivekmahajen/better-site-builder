# Postgres connection string used by the booking + order-tracking backend.
# Local dev example (no SSL):
#   POSTGRES_URL=postgres://user:password@localhost:5432/aastha
#
# On Vercel: add a Vercel Postgres / Neon integration and it injects POSTGRES_URL
# automatically. Neon/managed providers require SSL (handled in lib/db.js).
POSTGRES_URL=

# Optional: enables AI-personalised readings in the Puja Calculator (server-side,
# via the Anthropic SDK). Without it, the calculator uses a built-in rule-based
# Jyotish engine, so the feature works either way.
ANTHROPIC_API_KEY=

# Devi's synthesized voice (premium ElevenLabs TTS via the /api/tts proxy).
# REQUIRED for the synthesized voice. Without ELEVENLABS_API_KEY, /api/tts
# returns 503 and Devi falls back to the browser's built-in speech voice.
# To RESTORE the synthesized voice: set these in your host (e.g. Vercel) and redeploy.
ELEVENLABS_API_KEY=
# English female voice id (defaults to "Rachel" 21m00Tcm4TlvDq8ikWAM if unset).
ELEVENLABS_VOICE_ID=
# Hindi female voice id (used for Devanagari / hi replies; falls back to browser if unset).
ELEVENLABS_VOICE_ID_HI=
# Optional model override for the English voice (default: eleven_turbo_v2_5).
# ELEVENLABS_MODEL=eleven_turbo_v2_5
